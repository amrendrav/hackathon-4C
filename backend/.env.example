# Copy this file to .env and fill in the values
# cp .env.example .env

# Required: Anthropic API key for all 7 agents + synthesis LLM calls
ANTHROPIC_API_KEY=sk-ant-...

# Required: Absolute path to aci.duckdb (built by build_pipeline.py on Day 1)
# Example: /Users/yourname/workspace/hackathon/db/aci.duckdb
ACI_DB_PATH=/path/to/hackathon/db/aci.duckdb
